<Window x:Class="NapaMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:NapaMonitor.ViewModels"
        Title="NAPA Monitor — PostgreSQL Health Dashboard"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A9EFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0B0"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="RedBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#FFC107"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A8EEF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3A3A4E"/>
                                <Setter Property="Foreground" Value="#606070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4A9EFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2A2A3E" BorderThickness="0,0,0,1" BorderBrush="#3A3A4E">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#4A9EFF" Margin="0,0,10,0"/>
                    <TextBlock Text="NAPA Monitor" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="PostgreSQL Health Dashboard" FontSize="12"
                               Foreground="#A0A0B0" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock Text="Interval (s):" Foreground="#A0A0B0"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <TextBox Width="50" Height="28"
                             Background="#1E1E2E" Foreground="White"
                             BorderBrush="#4A9EFF" BorderThickness="1"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontSize="12"
                             Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,12,0"/>
                    <Button Content="▶  Start" Style="{StaticResource PrimaryButton}"
                            Click="StartButton_Click"
                            IsEnabled="{Binding IsCollecting, Converter={x:Static s:BooleanNegationConverter.Instance}}"
                            Margin="0,0,8,0"/>
                    <Button Content="■  Stop" Style="{StaticResource DangerButton}"
                            Click="StopButton_Click"
                            IsEnabled="{Binding IsCollecting}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="16,12,16,12">

            <!-- OVERVIEW TAB -->
            <TabItem Header="Overview">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Metric Cards -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Current Metrics" Foreground="#A0A0B0"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Rows="2" Columns="2" Margin="0,0,0,12">
                            <!-- Active Connections -->
                            <Border Style="{StaticResource Card}" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE CONNECTIONS" Foreground="#A0A0B0"
                                               FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LatestSnapshot.ActiveConnections, FallbackValue='—'}"
                                               Foreground="#4A9EFF" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <TextBlock Foreground="#A0A0B0" FontSize="11">
                                        <Run Text="of "/>
                                        <Run Text="{Binding LatestSnapshot.MaxConnections, FallbackValue='—'}"/>
                                        <Run Text=" max"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Cache Hit Ratio -->
                            <Border Style="{StaticResource Card}" Margin="6,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="CACHE HIT RATIO" Foreground="#A0A0B0"
                                               FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="#4CAF50" FontSize="36" FontWeight="Bold" Margin="0,4,0,0">
                                        <Run Text="{Binding LatestSnapshot.CacheHitRatio, FallbackValue='—'}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                    <TextBlock Text="Ideal: above 99%" Foreground="#A0A0B0" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Database Size -->
                            <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="DATABASE SIZE" Foreground="#A0A0B0"
                                               FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="#FFC107" FontSize="36" FontWeight="Bold" Margin="0,4,0,0">
                                        <Run Text="{Binding LatestSnapshot.DatabaseSizeMb, StringFormat='{}{0:F1}', FallbackValue='—'}"/>
                                        <Run Text=" MB"/>
                                    </TextBlock>
                                    <TextBlock Text="Current database" Foreground="#A0A0B0" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Slow Queries -->
                            <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="SLOW QUERIES" Foreground="#A0A0B0"
                                               FontSize="10" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LatestSnapshot.SlowQueries.Count, FallbackValue='—'}"
                                               Foreground="#F44336" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <TextBlock Text="Queries over 1 second" Foreground="#A0A0B0" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Slow Queries List -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SLOW QUERIES DETAIL" Foreground="#A0A0B0"
                                           FontSize="10" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding LatestSnapshot.SlowQueries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E1E2E" CornerRadius="6"
                                                    Padding="10,8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="#F44336" CornerRadius="4"
                                                            Padding="6,2" Margin="0,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Foreground="White" FontSize="11" FontWeight="Bold">
                                                            <Run Text="{Binding DurationSeconds, StringFormat='{}{0:F1}'}"/>
                                                            <Run Text="s"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Query}"
                                                               Foreground="#E0E0E0" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontFamily="Consolas"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No slow queries detected"
                                           Foreground="#606070" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LatestSnapshot.SlowQueries.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- AI Quick Summary Panel -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="AI QUICK ANALYSIS" Foreground="#A0A0B0"
                                       FontSize="10" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>
                            <Button Content="Analyze with Groq"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AnalyzeButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,12"/>
                            <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding AiAnalysis, FallbackValue='Click Analyze to get AI insights.'}"
                                           Foreground="#E0E0E0" FontSize="12"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- HISTORY TAB -->
            <TabItem Header="History">
                <Border Style="{StaticResource Card}">
                    <DataGrid ItemsSource="{Binding SnapshotHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="#2A2A3E"
                              AlternatingRowBackground="#252535"
                              Foreground="White"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#3A3A4E"
                              ColumnHeaderHeight="36">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#A0A0B0"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Width="160"
                                                Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                            <DataGridTextColumn Header="Active Connections" Width="*"
                                                Binding="{Binding ActiveConnections}"/>
                            <DataGridTextColumn Header="Cache Hit %" Width="*"
                                                Binding="{Binding CacheHitRatio}"/>
                            <DataGridTextColumn Header="DB Size (MB)" Width="*"
                                                Binding="{Binding DatabaseSizeMb, StringFormat='{}{0:F2}'}"/>
                            <DataGridTextColumn Header="Slow Queries" Width="*"
                                                Binding="{Binding SlowQueries.Count}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- AI TAB -->
            <TabItem Header="AI Analysis">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Gemini Analysis" Foreground="White"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Content="✦  Run Analysis" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Right"
                                    Click="AnalyzeButton_Click"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
                            <TextBlock Text="{Binding AiAnalysis, FallbackValue='No analysis yet. Click Run Analysis to start.'}"
                                       Foreground="#E0E0E0" FontSize="13"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#2A2A3E" BorderThickness="0,1,0,0" BorderBrush="#3A3A4E">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#606070"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCollecting}" Value="True">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A0B0" FontSize="12"/>
                </StackPanel>
                <TextBlock Text="{Binding SnapshotHistory.Count, StringFormat='Snapshots collected: {0}'}"
                           Foreground="#606070" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>